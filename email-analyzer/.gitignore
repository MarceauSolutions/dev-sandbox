# Email Analyzer .gitignore

# Email files (may contain sensitive information)
data/*.html
data/*.eml
data/*.msg
*.html
*.eml
*.msg

# Sensitive output
**/analysis-output/*.md
**/personal-emails/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
tmp/
temp/
.tmp/

# Environment variables
.env
.env.local
