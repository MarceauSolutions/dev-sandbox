# Fitness Influencer AI - Environment Variables

# AI Services (Required)
ANTHROPIC_API_KEY=your_anthropic_api_key
XAI_API_KEY=your_xai_api_key

# Video Services (Optional - for video ad creation)
SHOTSTACK_API_KEY=your_shotstack_api_key

# Google APIs (Optional - for email/sheets)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Stripe Configuration (Required for paid tiers)
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Payment Links (for landing page)
# Create these in Stripe Dashboard > Payment Links
STRIPE_LINK_STARTER_MONTHLY=https://buy.stripe.com/starter_monthly
STRIPE_LINK_STARTER_ANNUAL=https://buy.stripe.com/starter_annual
STRIPE_LINK_PRO_MONTHLY=https://buy.stripe.com/pro_monthly
STRIPE_LINK_PRO_ANNUAL=https://buy.stripe.com/pro_annual
STRIPE_LINK_AGENCY_MONTHLY=https://buy.stripe.com/agency_monthly
STRIPE_LINK_AGENCY_ANNUAL=https://buy.stripe.com/agency_annual
