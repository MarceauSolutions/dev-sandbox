{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wmarceau/amazon-seller",
  "description": "Amazon seller tools: FBA fees, inventory optimization, restock recommendations.",
  "repository": {
    "url": "https://github.com/MarceauSolutions/dev-sandbox",
    "source": "github",
    "subfolder": "projects/amazon-seller"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "amazon-seller-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "runtime": "python",
      "environmentVariables": [
        {
          "name": "AMAZON_REFRESH_TOKEN",
          "description": "Amazon SP-API refresh token",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "AMAZON_LWA_APP_ID",
          "description": "Amazon LWA App ID (Client ID)",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "AMAZON_LWA_CLIENT_SECRET",
          "description": "Amazon LWA Client Secret",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
