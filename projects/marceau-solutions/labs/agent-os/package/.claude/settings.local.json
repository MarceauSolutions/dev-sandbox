{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(pwd:*)",
      "Bash(tree:*)",
      "Bash(chmod:*)",
      "Bash(open:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(tar:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check-existing-tools.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/project-structure-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/api-cost-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/destructive-guard.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/stack-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/complete-the-loop-guard.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
