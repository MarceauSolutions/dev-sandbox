[Unit]
Description=AI Phone Agent — Twilio-first inbound call handler (gunicorn)
After=network.target n8n.service

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/clawdbot/dev-sandbox/projects/marceau-solutions/labs/ai-phone-agent/src
ExecStart=/home/ec2-user/.local/bin/gunicorn -c gunicorn_conf.py app:app
Restart=always
RestartSec=10
Environment=HOME=/home/ec2-user
Environment=AI_PHONE_ENV_PATH=/home/clawdbot/dev-sandbox/.env
Environment=BIND=0.0.0.0:8795
Environment=WEB_CONCURRENCY=3

[Install]
WantedBy=multi-user.target
