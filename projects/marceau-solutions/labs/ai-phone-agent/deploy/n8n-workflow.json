{
  "name": "AI Phone Lead Processor",
  "description": "Handles incoming leads from AI phone agent - adds to dashboard, sends email notification, logs to sheet",
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [100, 300],
      "parameters": {
        "path": "ai-phone-lead",
        "responseMode": "onReceived",
        "responseData": "allEntries"
      }
    },
    {
      "name": "Add to Dashboard",
      "type": "n8n-nodes-base.httpRequest",
      "position": [300, 200],
      "parameters": {
        "url": "http://localhost:8796/api/leads",
        "method": "POST",
        "sendBody": true,
        "bodyContentType": "json",
        "bodyParameters": {
          "parameters": [
            { "name": "phone", "value": "={{ $json.phone }}" },
            { "name": "source", "value": "={{ $json.source }}" },
            { "name": "status", "value": "={{ $json.status }}" },
            { "name": "collected_data", "value": "={{ $json.collected_data }}" },
            { "name": "call_sid", "value": "={{ $json.call_sid }}" },
            { "name": "recording_url", "value": "={{ $json.recording_url }}" }
          ]
        }
      }
    },
    {
      "name": "Send Email",
      "type": "n8n-nodes-base.gmail",
      "position": [300, 400],
      "parameters": {
        "operation": "sendEmail",
        "sendTo": "wmarceau@marceausolutions.com",
        "subject": "🔥 New AI Services Lead - {{ $json.phone }}",
        "message": "New lead from AI phone agent!\n\nPhone: {{ $json.phone }}\nSource: {{ $json.source }}\nStatus: {{ $json.status }}\n\nBusiness Type: {{ $json.collected_data.business_type }}\nPain Points: {{ $json.collected_data.pain_points }}\nTimeline: {{ $json.collected_data.timeline }}\n\n---\nView all leads: https://leads.marceausolutions.com"
      }
    },
    {
      "name": "Log to Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "position": [500, 300],
      "parameters": {
        "operation": "append",
        "sheetId": "YOUR_SHEET_ID",
        "range": "Leads!A:G",
        "options": {},
        "fieldsUi": {
          "values": [
            { "column": "A", "value": "={{ $json.timestamp }}" },
            { "column": "B", "value": "={{ $json.phone }}" },
            { "column": "C", "value": "={{ $json.source }}" },
            { "column": "D", "value": "={{ $json.status }}" },
            { "column": "E", "value": "={{ $json.collected_data.business_type }}" },
            { "column": "F", "value": "={{ $json.collected_data.pain_points }}" },
            { "column": "G", "value": "={{ $json.recording_url }}" }
          ]
        }
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          { "node": "Add to Dashboard", "type": "main", "index": 0 },
          { "node": "Send Email", "type": "main", "index": 0 },
          { "node": "Log to Sheet", "type": "main", "index": 0 }
        ]
      ]
    }
  }
}
