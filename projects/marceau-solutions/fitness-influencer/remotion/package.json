{
  "name": "fitness-influencer-remotion",
  "version": "1.0.0",
  "private": true,
  "description": "Animated video elements for fitness influencer content (Ryan Humiston style)",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts",
    "render:intro": "remotion render src/index.ts FitnessIntro --output=out/intro.mp4",
    "render:textbomb": "remotion render src/index.ts TextBomb --output=out/textbomb.mp4",
    "render:stat": "remotion render src/index.ts ExerciseStat --output=out/stat.mp4",
    "render:beforeafter": "remotion render src/index.ts BeforeAfter --output=out/beforeafter.mp4",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.0",
    "@remotion/player": "4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
