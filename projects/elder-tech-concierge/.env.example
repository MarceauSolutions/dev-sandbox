# Elder Tech Concierge - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# SMTP Configuration (for Procurement Emails)
# =============================================================================
# Using Google Workspace SMTP with App Password
#
# To get an App Password:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Mac" (or your device)
# 3. Generate the 16-character app password
# 4. Use that password below (NOT your regular Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=wmarceau@marceausolutions.com
SMTP_PASS=your-16-char-app-password

# Sender identity for procurement emails
SMTP_FROM=wmarceau@marceausolutions.com
SENDER_NAME=William Marceau
COMPANY_NAME=Marceau Solutions

# Mock mode - set to 'false' to send real emails
PROCUREMENT_MOCK_EMAIL=false

# =============================================================================
# Client Management
# =============================================================================
# Database path for client data
CLIENT_DB_PATH=./data/clients.db

# =============================================================================
# Third-Party Services
# =============================================================================

# Claude API (for AI assistant features)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Twilio (for SMS and voice calls)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Google APIs (Calendar, Gmail)
# Use credentials from ~/.time-blocks/ for personal Google account
# Or configure separate Google Workspace credentials here
GOOGLE_APPLICATION_CREDENTIALS=path-to-service-account.json

# =============================================================================
# Server Configuration
# =============================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=true
