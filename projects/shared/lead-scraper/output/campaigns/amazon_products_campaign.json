{
  "campaign_id": "amazon_products_jan2026",
  "campaign_name": "Amazon Products - FBA Automation Outreach",
  "created_at": "2026-01-30",
  "status": "draft",

  "target_audience": {
    "description": "Amazon FBA sellers and e-commerce entrepreneurs",
    "apollo_profile": "amazon_sellers",
    "filters": {
      "verified_email_only": true,
      "location": null,
      "employee_range": ["1,1", "1,10", "11,50"]
    },
    "pain_points": ["amazon_seller", "fba", "sp-api", "inventory", "profit", "reporting"]
  },

  "templates": {
    "initial": "amazon_seller_discovery",
    "alternatives": [
      "amazon_restock",
      "amazon_reporting",
      "amazon_profit"
    ],
    "followup_sequence": [
      {
        "day": 3,
        "template": "amazon_followup_1"
      },
      {
        "day": 7,
        "template": "amazon_still_looking"
      },
      {
        "day": 14,
        "template": "followup_checkin"
      },
      {
        "day": 30,
        "template": "breakup"
      }
    ]
  },

  "schedule": {
    "daily_limit": 50,
    "send_window": {
      "start_hour": 9,
      "end_hour": 17,
      "timezone": "America/New_York"
    },
    "days_of_week": ["monday", "tuesday", "wednesday", "thursday", "friday"],
    "delay_between_emails_seconds": 30
  },

  "tracking": {
    "utm_source": "cold_email",
    "utm_medium": "email",
    "utm_campaign": "amazon_products_jan2026",
    "sync_to_clickup": true,
    "clickup_list": "hot_leads"
  },

  "compliance": {
    "include_unsubscribe": true,
    "check_opt_out_list": true,
    "respect_can_spam": true
  },

  "notes": "Campaign targeting Amazon FBA sellers with SP-API automation tools. Focus on pain points: restock decisions, profit calculations, automated reporting."
}
