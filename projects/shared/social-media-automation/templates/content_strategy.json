  "content_templates": {
    "workout_tip": {
      "structure": "Hook + Tip + CTA",
      "example": "Stop doing [common mistake]! Here's why: [explanation]. Try this instead: [better approach]. Save this for your next workout."
    },
    "question_hook": {
      "structure": "Question + Value + Engagement ask",
      "example": "What's your biggest fitness struggle right now? Mine was [struggle] until I discovered [solution]. Drop yours below."
    },
    "value_list": {
      "structure": "Number + Promise + Bullet points",
      "example": "5 exercises that changed my physique:\n\n1. [Exercise]\n2. [Exercise]\n...\n\nWhich one are you adding to your routine?"
    },
    "social_proof": {
      "structure": "Result + Story + Method",
      "example": "My client lost 20lbs in 3 months. Here's exactly what we did: [method]. The key was [insight]."
    },
    "pain_point": {
      "structure": "Problem + Empathy + Solution",
      "example": "Feeling stuck in your fitness journey? You're not alone. 90% of people quit in the first 3 months. Here's how to be in the 10%..."
    }
  },

