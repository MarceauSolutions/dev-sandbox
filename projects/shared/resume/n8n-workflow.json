{
  "name": "Resume Builder - Webhook Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "resume-builder",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Resume Builder Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 300],
      "webhookId": "resume-builder-webhook"
