{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.marceausolutions/upwork",
  "description": "MCP server for Upwork job discovery, client analysis, and proposal assistance",
  "repository": {
    "url": "https://github.com/MarceauSolutions/upwork-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "upwork-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "runtime": "python",
      "environmentVariables": [
        {
          "name": "UPWORK_CLIENT_ID",
          "description": "Upwork API client ID from developer portal"
        },
        {
          "name": "UPWORK_CLIENT_SECRET",
          "description": "Upwork API client secret"
        },
        {
          "name": "UPWORK_REDIRECT_URI",
          "description": "OAuth redirect URI (default: https://localhost)"
        }
      ]
    }
  ]
}
