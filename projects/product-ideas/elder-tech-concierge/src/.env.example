# Elder Tech Concierge - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: Claude AI API
# ============================================================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============================================================================
# OPTIONAL: Twilio SMS
# ============================================================================
# Sign up at: https://www.twilio.com/
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ============================================================================
# OPTIONAL: Google APIs (Gmail & Calendar)
# ============================================================================
# 1. Go to https://console.cloud.google.com
# 2. Create a project
# 3. Enable Gmail API and Calendar API
# 4. Create OAuth 2.0 credentials (Desktop app)
# 5. Download credentials.json and place in src/ directory

# ============================================================================
# EMERGENCY CONTACTS (Format: Name|Phone|Email|Relationship)
# ============================================================================
# Add up to 5 emergency contacts
EMERGENCY_CONTACT_1=John Doe|+15551234567|john@example.com|Son
EMERGENCY_CONTACT_2=Jane Doe|+15559876543|jane@example.com|Daughter
# EMERGENCY_CONTACT_3=
# EMERGENCY_CONTACT_4=
# EMERGENCY_CONTACT_5=

# ============================================================================
# FAMILY CONTACTS (Format: Name|Phone|Email|Relationship)
# ============================================================================
# Add up to 10 family contacts
FAMILY_CONTACT_1=Sarah|+15551111111|sarah@example.com|Daughter
FAMILY_CONTACT_2=Mike|+15552222222|mike@example.com|Son
FAMILY_CONTACT_3=Emily|+15553333333|emily@example.com|Granddaughter
# FAMILY_CONTACT_4=
# FAMILY_CONTACT_5=
# FAMILY_CONTACT_6=
# FAMILY_CONTACT_7=
# FAMILY_CONTACT_8=
# FAMILY_CONTACT_9=
# FAMILY_CONTACT_10=
