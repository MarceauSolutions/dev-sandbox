{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wmarceau/apollo",
  "description": "Apollo.io lead enrichment and prospecting via MCP",
  "repository": {
    "url": "https://github.com/MarceauSolutions/dev-sandbox",
    "source": "github",
    "subfolder": "projects/apollo-mcp"
  },
  "version": "1.1.1",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "apollo-mcp",
      "version": "1.1.1",
      "transport": {
        "type": "stdio"
      },
      "runtime": "python",
      "environmentVariables": [
        {
          "name": "APOLLO_API_KEY",
          "description": "Your Apollo.io API key from https://app.apollo.io/settings/integrations",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
