{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wmarceau/twilio",
  "description": "Twilio SMS tools for Claude - check inbox, send messages, track leads",
  "repository": {
    "url": "https://github.com/wmarceau/twilio-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "twilio-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "runtime": "python",
      "environmentVariables": [
        {
          "name": "TWILIO_ACCOUNT_SID",
          "description": "Twilio Account SID"
        },
        {
          "name": "TWILIO_AUTH_TOKEN",
          "description": "Twilio Auth Token"
        },
        {
          "name": "TWILIO_PHONE_NUMBER",
          "description": "Twilio phone number in E.164 format"
        }
      ]
    }
  ]
}
