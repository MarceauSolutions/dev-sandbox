{
  "$schema": "https://registry.modelcontextprotocol.io/schemas/manifest.json",
  "name": "Amazon Seller Operations",
  "version": "1.0.0",
  "description": "Comprehensive Amazon seller tools for FBA inventory management, fee calculation (2026 structure), and optimization recommendations. Integrates with Amazon SP-API.",
  "author": {
    "name": "William Marceau Jr.",
    "github": "williammarceaujr"
  },
  "license": "MIT",
  "homepage": "https://github.com/williammarceaujr/amazon-seller",
  "repository": {
    "type": "git",
    "url": "https://github.com/williammarceaujr/amazon-seller.git"
  },
  "categories": [
    "e-commerce",
    "amazon",
    "fba",
    "inventory"
  ],
  "keywords": [
    "amazon",
    "seller",
    "fba",
    "sp-api",
    "inventory",
    "fees",
    "profit",
    "restock",
    "e-commerce"
  ],
  "tools": [
    {
      "name": "get_inventory_summary",
      "description": "Get FBA inventory levels for products"
    },
    {
      "name": "get_orders",
      "description": "Get recent orders from seller account"
    },
    {
      "name": "get_order_items",
      "description": "Get line items for specific order"
    },
    {
      "name": "get_product_details",
      "description": "Get product dimensions and pricing"
    },
    {
      "name": "calculate_fba_fees",
      "description": "Calculate comprehensive FBA fees (2026 structure)"
    },
    {
      "name": "estimate_profit_margin",
      "description": "Quick profit margin estimation"
    },
    {
      "name": "suggest_restock_quantities",
      "description": "Intelligent reorder recommendations"
    },
    {
      "name": "analyze_sell_through_rate",
      "description": "Calculate sales velocity"
    }
  ],
  "requirements": {
    "python": ">=3.8",
    "packages": [
      "python-amazon-sp-api",
      "python-dotenv",
      "mcp"
    ]
  },
  "authentication": {
    "type": "oauth2",
    "provider": "Amazon Login with Amazon",
    "required_credentials": [
      "AMAZON_REFRESH_TOKEN",
      "AMAZON_LWA_APP_ID",
      "AMAZON_LWA_CLIENT_SECRET",
      "AMAZON_AWS_ACCESS_KEY",
      "AMAZON_AWS_SECRET_KEY",
      "AMAZON_ROLE_ARN"
    ]
  },
  "connectivity": "HTTP",
  "pricing": {
    "model": "free_with_api_costs",
    "notes": "Free to use. Requires Amazon SP-API access. Note: Amazon charges for GET calls starting April 30, 2026."
  },
  "features": [
    "2026 FBA fee structure",
    "Multi-marketplace support",
    "Aggressive caching (cost optimization)",
    "Aged inventory surcharge calculation",
    "Stockout risk assessment",
    "Profit margin analysis"
  ]
}
