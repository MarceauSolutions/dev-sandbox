# API Keys and Credentials
# Copy this file to .env and fill in your actual values

# Google Cloud (for Sheets, Slides, etc.)
# GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Modal (for webhooks)
# MODAL_TOKEN_ID=your-modal-token-id
# MODAL_TOKEN_SECRET=your-modal-token-secret

# Slack (for notifications)
# SLACK_WEBHOOK_URL=your-slack-webhook-url
# SLACK_BOT_TOKEN=your-slack-bot-token

# Email Configuration (for client onboarding and notifications)
# Gmail/Google Workspace SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@marceausolutions.com
SMTP_PASSWORD=your-gmail-app-password

# Email sender details
SENDER_NAME=Marceau Solutions
SENDER_EMAIL=your-email@marceausolutions.com

# Calendly link for client kickoff calls
CALENDLY_URL=https://calendly.com/your-username/kickoff-call

